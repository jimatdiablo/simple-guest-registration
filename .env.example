APP_NAME=Simple Guest Registration
APP_TITLE=Customer Guest Registration
APP_ENV=dev
APP_URL=http://192.168.160.4
APP_TIMEZONE=America/New_York
APP_VERSION=dev
APP_BUILD_DATE=
APP_IMAGE_TAG=

# Production compose image references.
SGR_APP_IMAGE=ghcr.io/jimatdiablo/simple-guest-registration:latest
SGR_DNS_IMAGE=ghcr.io/jimatdiablo/simple-guest-registration-dns:latest
SGR_HTTP_BIND=192.168.160.4:80
SGR_APP_CONTAINER_NAME=sgr_app
SGR_SCHEDULER_CONTAINER_NAME=sgr_scheduler
SGR_DNS_CONTAINER_NAME=sgr_dns
SGR_DB_CONTAINER_NAME=sgr_db
SGR_DB_VOLUME=sgr_db_data
SGR_APP_STORAGE_VOLUME=sgr_app_storage

# Lab poison DNS. Guest DHCP should point unregistered clients at POISON_DNS_BIND_IP.
POISON_DNS_BIND_IP=192.168.160.4
POISON_DNS_TARGET_IP=192.168.160.4
POISON_DNS_UPSTREAM_SERVERS=1.1.1.1,8.8.8.8

DB_HOST=db
DB_PORT=3306
DB_NAME=guest_registration
DB_USER=guestapp
DB_PASSWORD=change-me-app-password
MYSQL_ROOT_PASSWORD=change-me-root-password

# Optional comma-separated protected master-admin seeds for first deployment.
# Format: username:password,username2:password2
# Do not commit real production passwords.
SGR_MASTER_ADMIN_SEEDS=

# Comma-separated service groups. Testing defaults are SG 10 and SG 11.
SERVICE_GROUPS=10,11
DEFAULT_SERVICE_PROFILE=10baseservice
# Comma-separated unit values that mark undeployed/spare modems in Gunslinger (case-insensitive).
# Modems with these unit values are excluded from lot caching, lot dropdowns, and lease alerts.
MODEM_EXCLUDED_UNIT_VALUES=stock
ADMIN_ACCESS_KEY=

# Gunslinger integration endpoints (leave blank to skip integration in local prototype).
GUNSLINGER_REFRESH_URL=
GUNSLINGER_PROFILE_UPDATE_URL=
GUNSLINGER_PROFILE_BOOTFILE_URL=
GUNSLINGER_API_TOKEN=
GUNSLINGER_REFRESH_API_KEY=
GUNSLINGER_UPDATE_ALLOWED_SGS=10,11
GUNSLINGER_TIMEOUT=10

# DDNet integration
DDNET_BASE_URL=http://192.168.160.220:4000/api/dhcp
DDNET_TIMEOUT=10

# SNMP reboot integration
SNMP_ENABLED=false
SNMP_COMMUNITY=private
SNMP_REBOOT_OID=1.3.6.1.2.1.69.1.1.3.0
SNMP_REBOOT_VALUE=i 1
SNMP_TIMEOUT=3
SNMP_RETRIES=3
SNMP_RETRY_DELAY_MS=750
SNMP_AUDIT_LOG_ENABLED=true
SNMP_AUDIT_LOG_PATH=/var/www/html/storage/logs/snmp_audit.log
